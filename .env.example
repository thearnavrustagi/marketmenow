# Figma
FIGMA_API_TOKEN=

# TTS provider: elevenlabs, openai, or local
TTS_PROVIDER=elevenlabs

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# OpenAI TTS
OPENAI_API_KEY=
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_MODEL=tts-1

# Google Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=vertex.json
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1

# Instagram Graph API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# User-defined secret for Meta webhook verification
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# S3 media hosting (Instagram Graph API needs publicly accessible media URLs)
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_PREFIX=instagram/uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Twitter / X
# Option 1: cookie login (recommended) -- grab from DevTools > Application > Cookies > x.com
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
# Option 2: manual browser login (leave blank, run `mmn twitter login`)
TWITTER_USERNAME=
TWITTER_PASSWORD=

# LinkedIn
# ── Option 1 (recommended): REST API ──
# Create an app at https://www.linkedin.com/developers/apps, enable
# "Share on LinkedIn" or "Community Management API", then generate an
# OAuth 2.0 access token with w_member_social / w_organization_social.
LINKEDIN_ACCESS_TOKEN=
# Your person URN (urn:li:person:xxx) -- find via GET /v2/userinfo
LINKEDIN_PERSON_URN=
# API version -- defaults to 202504
# LINKEDIN_API_VERSION=202504

# ── Option 2: browser fallback ──
# Cookie login -- grab from DevTools > Application > Cookies > linkedin.com
LINKEDIN_LI_AT=

# Organization / company page numeric ID (posts go to company page instead of personal feed)
LINKEDIN_ORGANIZATION_ID=

# Facebook
# Cookie login -- grab c_user and xs from DevTools > Application > Cookies > facebook.com
FACEBOOK_C_USER=
FACEBOOK_XS=
# Comma-separated group IDs or URLs for teacher group posting
FACEBOOK_GROUP_IDS=
# Or leave blank and run `mmn facebook login` for manual browser login

# YouTube Shorts
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the YouTube Data API v3
# 3. Create OAuth 2.0 credentials (Desktop app type)
# 4. Run `mmn youtube auth` to get a refresh token
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# Privacy for uploads: public, unlisted, or private (default: private)
YOUTUBE_DEFAULT_PRIVACY=private
# YouTube category ID (default: 27 = Education)
YOUTUBE_DEFAULT_CATEGORY_ID=27

# Reddit
# Cookie login -- grab reddit_session from DevTools > Application > Cookies > reddit.com
REDDIT_SESSION=
REDDIT_USERNAME=your_reddit_username

# Email / SMTP (for `mmn email send`)
SMTP_HOST=smtp.mail.us-east-1.awsapps.com
SMTP_PORT=465
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=you@example.com
SMTP_FROM_NAME=Your Name
SMTP_USE_TLS=false
SMTP_USE_SSL=true

# Output
OUTPUT_DIR=output/

# Web Dashboard
# Local (docker-compose up): postgresql://mmn:mmn@localhost:5432/marketmenow
# Neon / remote:             postgresql://user:pass@host/neondb?sslmode=require
MMN_WEB_DATABASE_URL=postgresql://mmn:mmn@localhost:5432/marketmenow

# Batch "Generate & Publish All" settings
MMN_WEB_BATCH_EMAIL_TEMPLATE=templates/sharegradeasy.html
MMN_WEB_BATCH_EMAIL_CSV=vault/teachers.csv
MMN_WEB_BATCH_EMAIL_SIZE=100
